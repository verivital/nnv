# NNV3.0 — exclude per-run outputs and decompressed assets.
# The shipped artifact is just code + small bundled .mat / .onnx / .npy files.

# Per-run output dirs (timestamped — generated by run scripts).
**/results/run_all_*/
**/results/gnn_*/
**/results/probver_*/
**/results/fairnnv_*/
**/results/zoomin_*/
**/results/[0-9][0-9][0-9][0-9][0-9][0-9]-*/

# Generated CSVs / TeX / figures inside results/.
**/results/*.csv
**/results/*.tex
**/figures/*.png
**/figures/*.pdf

# ProbVer decompressed artifacts (recompressed sources are tracked).
ProbVer/yolo_2023/onnx/*.onnx
!ProbVer/yolo_2023/onnx/*.onnx.gz
ProbVer/yolo_2023/vnnlib/*.vnnlib
!ProbVer/yolo_2023/vnnlib/*.vnnlib.gz

# Auto-generated MATLAB package created when importONNXNetwork loads
# TinyYOLO inside ProbVer (MATLAB caches helper classes here).
ProbVer/+TinyYOLO/

# ModelStar runtime diary and the populated YAML clone (template stays).
ModelStar/runtime/
ModelStar/results/MNIST_MLP.yaml

# MATLAB session detritus.
*.log
*.bak
*.asv
slprj/

# OS / editor noise.
.DS_Store
*~
